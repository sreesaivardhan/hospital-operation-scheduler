rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isOwnerUnverified(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isPatient() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'patient';
    }

    function isStaffOrAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'user'];
    }

    // ── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwnerUnverified(userId) || isAdmin();
      allow create: if (isOwnerUnverified(userId) &&
                  (
                    (request.resource.data.role == 'patient' && request.resource.data.isActive == true) ||
                    (request.resource.data.role == 'user' && request.resource.data.isActive == false)
                  ) &&
                  request.resource.data.uid == request.auth.uid)
              || isAdmin();
      allow update: if isOwnerUnverified(userId) && 
                       !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
                       !('isActive' in request.resource.data.diff(resource.data).affectedKeys()) &&
                       !('status' in request.resource.data.diff(resource.data).affectedKeys()) &&
                       !('uid' in request.resource.data.diff(resource.data).affectedKeys())
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Doctors collection ──────────────────────────────────────────────────
    match /doctors/{doctorId} {
      allow read:   if request.auth != null;
      allow create,
            update,
            delete: if isAdmin();
    }

    // ── Patients collection ─────────────────────────────────────────────────
    match /patients/{patientId} {
      allow read:   if (request.auth != null && request.auth.uid == patientId) || isStaffOrAdmin();
      allow create: if (request.auth != null && request.auth.uid == patientId) || isAdmin();
      allow update: if isOwnerUnverified(patientId) && 
                       !('role' in request.resource.data.diff(resource.data).affectedKeys()) && 
                       !('isActive' in request.resource.data.diff(resource.data).affectedKeys()) && 
                       !('status' in request.resource.data.diff(resource.data).affectedKeys()) &&
                       !('uid' in request.resource.data.diff(resource.data).affectedKeys())
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── OT Rooms collection ─────────────────────────────────────────────────
    match /ot_rooms/{roomId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ── OT Schedules collection (JS uses 'ot_schedules') ───────────────────
    match /ot_schedules/{scheduleId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ── Staff support collections (read-only, may be empty) ────────────────
    match /anesthesiologists/{docId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    match /nurses/{docId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ── Appointments collection ─────────────────────────────────────────────
    match /appointments/{appointmentId} {
      allow create: if request.auth != null &&
                       request.resource.data.patientId == request.auth.uid &&
                       request.resource.data.status == "pending";
      allow read:   if (request.auth != null && resource.data.patientId == request.auth.uid) ||
                       isAdmin() ||
                       (request.auth != null && resource.data.doctorEmail == request.auth.token.email);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Admin Logs ──────────────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated();
      allow update,
            delete: if false;
    }
  }
}
